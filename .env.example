# Copy to `.env` and fill in. NEVER commit a real `.env`.

# Postgres (matches docker-compose.yml service `postgres`)
DATABASE_URL="postgresql://eps:eps@localhost:5432/eps?schema=public"

# Clerk (auth, email verify, 2FA) — dev instance test keys only, NEVER commit real values.
# Session tokens are verified server-side on every API route; userId/orgId come from the token.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Stripe Billing (TEST MODE ONLY — never a live-mode key; CLAUDE.md hard rule #7).
# STRIPE_SECRET_KEY drives scripts/stripe-bootstrap.ts and the checkout/webhook routes.
# The *_PRICE_ID values are printed by `pnpm tsx scripts/stripe-bootstrap.ts` — paste them here.
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_TIER1_PRICE_ID="price_xxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_TIER2_PRICE_ID="price_xxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_TIER3_PRICE_ID="price_xxxxxxxxxxxxxxxxxxxxxxxx"
